# Apollo API key (required). Get one at https://app.apollo.io/#/settings/integrations/api
VITE_APOLLO_API_KEY=

# In dev, use Vite proxy to avoid CORS (recommended). Set to "false" to call Apollo directly from the browser.
VITE_APOLLO_USE_DEV_PROXY=true

# Optional: override Apollo API base (production). Default https://api.apollo.io
# VITE_APOLLO_API_BASE_URL=https://api.apollo.io
